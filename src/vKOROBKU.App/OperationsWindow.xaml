<Window x:Class="vKOROBKU.App.OperationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:vKOROBKU.App.Resources"
        Title="{x:Static res:Strings.Operations_WindowTitle}" Icon="Assets/vkorobku.ico"
        Width="760" Height="620" MinWidth="620" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource TextBrush}">
    <Window.Resources>
        <DataTemplate x:Key="OperationCardTemplate">
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,10">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding GameName}" FontSize="16" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding OperationText}" Margin="0,4,0,0"
                                       Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding StateText}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding StartedText}" Margin="0,4,0,0" HorizontalAlignment="Right"
                                       Foreground="{StaticResource MutedTextBrush}" FontSize="10" />
                        </StackPanel>
                    </Grid>
                    <ProgressBar Height="7" Margin="0,13,0,0" Minimum="0" Maximum="100"
                                 Value="{Binding ProgressPercent, Mode=OneWay}" Background="#292D35"
                                 Foreground="{StaticResource AccentBrush}" BorderThickness="0" />
                    <TextBlock Text="{Binding ProgressText}" Margin="0,7,0,0" FontSize="10"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock Text="{Binding Message}" Margin="0,7,0,0" TextWrapping="Wrap" FontSize="11" />
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="NoCurrentOperationTemplate">
            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="18">
                <TextBlock Text="{x:Static res:Strings.Operations_NoActive}" Foreground="{StaticResource MutedTextBrush}" />
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{x:Static res:Strings.Nav_Operations}" FontSize="28" FontWeight="Bold" />
            <TextBlock Text="{x:Static res:Strings.Operations_Subtitle}"
                       Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ContentControl Content="{Binding CurrentOperation}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="ContentTemplate" Value="{StaticResource OperationCardTemplate}" />
                        <Style.Triggers>
                            <Trigger Property="Content" Value="{x:Null}">
                                <Setter Property="ContentTemplate" Value="{StaticResource NoCurrentOperationTemplate}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
            <Button Grid.Column="2" Content="{x:Static res:Strings.Operations_Stop}" Command="{Binding CancelCurrentCommand}"
                    VerticalAlignment="Center" Background="#A83A3A" Foreground="White" />
        </Grid>

        <TextBlock Grid.Row="3" Text="{x:Static res:Strings.Operations_History}" FontSize="10" FontWeight="Bold"
                   Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8" />
        <ListBox Grid.Row="4" ItemsSource="{Binding Operations}" ItemTemplate="{StaticResource OperationCardTemplate}"
                 Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Focusable" Value="False" />
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
    </Grid>
</Window>
