<Window x:Class="vKOROBKU.App.ManualGameIdentityWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:vKOROBKU.App.Resources"
        Title="{x:Static res:Strings.Panel_ReviewIdentity}" Width="500" Height="300" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="22" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="{x:Static res:Strings.Identity_Question}" FontSize="24" FontWeight="Bold" />
            <TextBlock Margin="0,7,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}"
                       Text="{x:Static res:Strings.Identity_Hint}" />
        </StackPanel>
        <StackPanel Grid.Row="2">
            <TextBlock Text="{x:Static res:Strings.Identity_NameLabel}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" />
            <TextBox x:Name="GameNameBox" Margin="0,7,0,0" Height="40" Padding="10,8"
                     Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                     BorderBrush="#353A44" CaretBrush="{StaticResource AccentBrush}" />
        </StackPanel>
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="{x:Static res:Strings.Identity_FindAndSave}" Click="SaveClick" />
            <Button Grid.Column="2" Content="{x:Static res:Strings.Settings_Cancel}" Click="CancelClick" Style="{StaticResource SecondaryButton}" />
        </Grid>
    </Grid>
</Window>
