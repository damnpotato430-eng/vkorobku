<Window x:Class="vKOROBKU.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:vKOROBKU.App.Resources"
        Title="vKOROBKU" Icon="Assets/vkorobku.ico"
        Width="1180" Height="820" MinWidth="1040" MinHeight="700"
        Background="{StaticResource BackgroundBrush}" Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#111318" BorderBrush="#252932" BorderThickness="0,0,1,0">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="vKOROBKU" FontSize="26" FontWeight="Black" Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="{x:Static res:Strings.Sidebar_Tagline}" Margin="0,4,0,0" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Border Background="#222B1D" CornerRadius="8" Padding="12,10">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}" Margin="0,0,9,0" />
                            <TextBlock Text="{x:Static res:Strings.Nav_Library}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Button Content="{x:Static res:Strings.Nav_Operations}" Command="{Binding ShowOperationsCommand}"
                            Margin="0,8,0,0" Style="{StaticResource SecondaryButton}" />
                    <Button Content="{x:Static res:Strings.Nav_Settings}" Command="{Binding ShowSettingsCommand}"
                            Margin="0,8,0,0" Style="{StaticResource SecondaryButton}" />
                    <Button Content="{x:Static res:Strings.Nav_About}" Command="{Binding ShowAboutCommand}"
                            Margin="0,8,0,0" Style="{StaticResource SecondaryButton}" />
                    <TextBlock Text="{x:Static res:Strings.Sidebar_AnalysisSection}" Margin="12,24,0,7" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock Text="{x:Static res:Strings.Sidebar_AnalysisHint}" Margin="12,0" TextWrapping="Wrap"
                               Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                </StackPanel>

                <Button Grid.Row="3" VerticalAlignment="Bottom" Margin="0,0,0,12"
                        Visibility="{Binding UpdateNoticeVisibility}" Command="{Binding OpenUpdateCommand}"
                        Content="{Binding UpdateNoticeText}" Style="{StaticResource SecondaryButton}"
                        Foreground="{StaticResource AccentBrush}" FontSize="12" Padding="10,8"
                        ToolTip="{x:Static res:Strings.Update_OpenPageTooltip}" />

                <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{x:Static res:Strings.Sidebar_SystemSection}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="{Binding Computer.ProcessorText}" Margin="0,7,0,0" TextWrapping="Wrap" FontSize="11"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="{Binding Computer.OperatingSystem}" Margin="0,4,0,0" TextWrapping="Wrap" FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Text="{Binding Computer.MemoryText}" Margin="0,4,0,0" FontSize="11"
                                   Foreground="{StaticResource MutedTextBrush}" />
                        <TextBlock Text="{x:Static res:Strings.Sidebar_CoversSource}" Margin="0,8,0,0" FontSize="10"
                                   Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="34,28,34,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="22" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Header_Title}" FontSize="30" FontWeight="Bold" />
                    <TextBlock Text="{x:Static res:Strings.Header_Subtitle}"
                               Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
                <Button Grid.Column="1" Content="{Binding ScanButtonText}" Command="{Binding RefreshLibraryCommand}"
                        Style="{StaticResource SecondaryButton}" VerticalAlignment="Center" />
                <Button Grid.Column="3" Content="{x:Static res:Strings.Header_RefreshCovers}" Command="{Binding RefreshCoversCommand}"
                        Style="{StaticResource SecondaryButton}" VerticalAlignment="Center"
                        ToolTip="{x:Static res:Strings.Header_RefreshCoversTooltip}" />
                <Button Grid.Column="5" Content="{x:Static res:Strings.Header_AddFolder}" Command="{Binding AddFolderCommand}"
                        VerticalAlignment="Center" />
            </Grid>

            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="18,15">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="{x:Static res:Strings.Drives_Section}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding TotalSavingsText}" FontSize="10"
                                       FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Text="{Binding AllTimeStatsText}" FontSize="10" FontWeight="Bold"
                                       Margin="10,0,0,0" Foreground="{StaticResource MutedTextBrush}"
                                       ToolTip="{Binding AllTimeStatsTooltip}" ToolTipService.InitialShowDelay="200">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AllTimeStatsText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Computer.Drives}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,6,8,0" Background="#111318" BorderBrush="#292D35" BorderThickness="1"
                                        CornerRadius="6" Padding="10,6">
                                    <Grid>
                                        <TextBlock Text="{Binding DisplayText}" />
                                        <TextBlock Text="{Binding SavingsText}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Grid Margin="0,10,0,0" Visibility="{Binding WatcherSummaryVisibility}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding WatcherSummaryText}" VerticalAlignment="Center"
                                   FontSize="11" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WatcherHasFindings}" Value="True">
                                            <Setter Property="Foreground" Value="#FFB84D" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="{x:Static res:Strings.Watcher_RecompressAll}" Command="{Binding RecompressDegradedCommand}"
                                    Padding="10,6" FontSize="11" Margin="12,0,0,0"
                                    ToolTip="{x:Static res:Strings.Watcher_RecompressAllTooltip}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WatcherHasFindings}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{x:Static res:Strings.Watcher_CheckNow}" Command="{Binding CheckWatchedGamesCommand}"
                                    Style="{StaticResource SecondaryButton}" Padding="10,6" FontSize="11"
                                    Margin="12,0,0,0" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="350" />
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="210" />
                        </Grid.ColumnDefinitions>
                        <Grid>
                            <TextBox x:Name="SearchBox" Height="34" Padding="12,0" VerticalContentAlignment="Center"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                                     BorderBrush="#353A44" CaretBrush="{StaticResource AccentBrush}" />
                            <TextBlock Text="{x:Static res:Strings.Search_Placeholder}" IsHitTestVisible="False" Margin="13,0,0,0" VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <ToggleButton Grid.Column="2" Margin="0,0,12,0" Padding="12,8" FontSize="12"
                                      VerticalAlignment="Center" Style="{StaticResource ExpertToggle}"
                                      IsChecked="{Binding IsMultiSelectMode, Mode=OneWay}"
                                      Command="{Binding ToggleMultiSelectCommand}"
                                      Content="{Binding MultiSelectToggleText}"
                                      ToolTip="{x:Static res:Strings.MultiSelect_Tooltip}" />
                        <ToggleButton Grid.Column="3" Margin="0,0,12,0" Padding="12,8" FontSize="12"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding ShowOnlyDegraded}"
                                      Content="{Binding DegradedFilterLabel}"
                                      ToolTip="{x:Static res:Strings.DegradedFilter_Tooltip}">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton" BasedOn="{StaticResource ExpertToggle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WatcherHasFindings}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                        <ComboBox Grid.Column="4" Height="34" VerticalContentAlignment="Center"
                                  ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSortOption}"
                                  Style="{StaticResource DarkComboBox}" ToolTip="{x:Static res:Strings.Sort_Tooltip}" />
                    </Grid>
                    <Border Margin="0,10,0,0" Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                            Padding="12,8" Visibility="{Binding MultiSelectVisibility}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding QueueSelectionText}" VerticalAlignment="Center" FontSize="12" />
                            <ComboBox Grid.Column="1" Width="200" Height="30" Margin="12,0,0,0" VerticalContentAlignment="Center"
                                      ItemsSource="{Binding QueueMethodOptions}" SelectedItem="{Binding SelectedQueueMethod}"
                                      Style="{StaticResource DarkComboBox}" ToolTip="{x:Static res:Strings.Queue_MethodTooltip}" />
                            <Button Grid.Column="2" Content="{x:Static res:Strings.Queue_Start}" Command="{Binding StartQueueCommand}"
                                    Margin="12,0,0,0" Padding="12,6" FontSize="12" />
                        </Grid>
                    </Border>
                    </StackPanel>
                    <ListBox Grid.Row="2" ItemsSource="{Binding GamesView}" SelectedItem="{Binding SelectedGame}"
                         Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            <Setter Property="Width" Value="260" />
                            <Setter Property="Margin" Value="0,0,14,14" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" />
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="OnGameItemPreviewMouseRightButtonDown" />
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="{x:Static res:Strings.Card_OpenFolder}" Command="{Binding OpenGameFolderCommand}" />
                                        <MenuItem Header="{x:Static res:Strings.Card_AddToQueue}" Command="{Binding AddToQueueCommand}" />
                                        <MenuItem Header="{x:Static res:Strings.Card_RefreshCover}" Command="{Binding RefreshSelectedCoverCommand}" />
                                        <MenuItem Header="{x:Static res:Strings.Card_RecheckState}" Command="{Binding RecheckCompressionCommand}" />
                                        <MenuItem Header="{x:Static res:Strings.Card_RemoveFromLibrary}" Command="{Binding RemoveGameCommand}" />
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Card" Background="{StaticResource SurfaceBrush}" CornerRadius="12"
                                                BorderBrush="Transparent" BorderThickness="1" Padding="17">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Card" Property="Background" Value="{StaticResource SurfaceHoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Border Height="120" Background="#101217" CornerRadius="9" ClipToBounds="True">
                                    <Grid>
                                        <TextBlock Text="▰" Foreground="{StaticResource AccentBrush}" FontSize="26"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <Image Source="{Binding CoverPath, Converter={StaticResource LocalImageConverter}}"
                                               Stretch="UniformToFill" />
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,6,6,0"
                                                Background="#CC14171D" CornerRadius="6" Padding="4"
                                                Visibility="{Binding DataContext.MultiSelectVisibility, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}">
                                            <CheckBox IsChecked="{Binding IsQueueSelected}" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding Name}" Margin="0,14,0,0" FontSize="17" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding InstallPath}" Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11" TextTrimming="CharacterEllipsis" />
                                <Grid Margin="0,15,0,0">
                                    <TextBlock Text="{Binding SourceText}" Foreground="{StaticResource AccentBrush}" FontSize="11" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding ActualSizeText}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,4,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasCompressedSize}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding SizeText}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasCompressedSize}" Value="True">
                                                            <Setter Property="Text" Value="{Binding OriginalSizeBracketText}" />
                                                            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                                <Border CornerRadius="5" Padding="8,4" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#20242C" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CompressionState}" Value="Compressed">
                                                    <Setter Property="Background" Value="#26331F" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CompressionState}" Value="PartiallyCompressed">
                                                    <Setter Property="Background" Value="#3A2E14" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding CompressionStatusText}" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CompressionState}" Value="Compressed">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CompressionState}" Value="PartiallyCompressed">
                                                        <Setter Property="Foreground" Value="#FFB84D" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CompressionState}" Value="Uncompressed">
                                                        <Setter Property="Foreground" Value="#C7CBD4" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <Border CornerRadius="5" Padding="8,4" Margin="6,0,0,0" Background="#1B2333"
                                        ToolTip="{x:Static res:Strings.Card_DirectStorageTooltip}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasDirectStorage}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="DirectStorage" FontSize="11" FontWeight="SemiBold" Foreground="#7FB2FF" />
                                </Border>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="{x:Static res:Strings.Panel_Section}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Text="{Binding SelectedGame.Name, TargetNullValue={x:Static res:Strings.Panel_NoGameSelected}}"
                                       Margin="0,7,0,0" FontSize="21" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SelectedGame.CompressionStatusText}" Margin="0,5,0,0" FontSize="12"
                                       FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                            <WrapPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <ToggleButton Content="{x:Static res:Strings.Panel_ExpertMode}" IsChecked="{Binding IsExpertMode}"
                                              Visibility="{Binding UncompressedPanelVisibility}"
                                              Style="{StaticResource ExpertToggle}" />
                                <Button Content="{x:Static res:Strings.Panel_ReviewIdentity}" Command="{Binding ReviewIdentityCommand}"
                                        Margin="8,0,0,0" Padding="10,6"
                                        Visibility="{Binding IdentityReviewVisibility}"
                                        Style="{StaticResource SecondaryButton}" />
                                <Button Content="{x:Static res:Strings.Card_RemoveFromLibrary}" Command="{Binding RemoveGameCommand}"
                                        Margin="8,0,0,0" Padding="10,6"
                                        Visibility="{Binding ManualGameVisibility}"
                                        Style="{StaticResource SecondaryButton}" />
                            </WrapPanel>
                            <StackPanel Visibility="{Binding UncompressedPanelVisibility}">
                                <Border Margin="0,10,0,0" Padding="10,8" Background="#1B2333" CornerRadius="6"
                                        Visibility="{Binding DirectStorageWarningVisibility}">
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#7FB2FF"
                                               Text="{x:Static res:Strings.Panel_DirectStorageWarning}" />
                                </Border>
                                <TextBlock Text="{Binding AnalysisSummary}" Margin="0,8,0,0" TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedTextBrush}" FontSize="13" />
                                <StackPanel Visibility="{Binding ExpertOptimizationVisibility}">
                                    <TextBlock Text="{x:Static res:Strings.Panel_AnalysisAccuracy}" Margin="0,13,0,5" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <ComboBox ItemsSource="{Binding AnalysisModes}" SelectedItem="{Binding SelectedAnalysisMode}"
                                              DisplayMemberPath="DisplayText" Height="34" Padding="8,4"
                                              Style="{StaticResource DarkComboBox}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Row="1" Margin="0,14,0,0" Background="#101217" CornerRadius="8" Padding="12,10"
                                Visibility="{Binding QueuePanelVisibility}">
                            <StackPanel>
                                <TextBlock Text="{Binding QueueTitle}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" />
                                <ItemsControl ItemsSource="{Binding QueueItems}" Margin="0,8,0,0" MaxHeight="180">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{Binding StatusText}" FontSize="11" Margin="8,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                    <Setter Property="Foreground" Value="#7FB2FF" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                    <Setter Property="Foreground" Value="#FF7A7A" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                                    <Setter Property="Foreground" Value="#FFB84D" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <WrapPanel Margin="0,8,0,0" Visibility="{Binding QueueControlsVisibility}">
                                    <Button Content="{x:Static res:Strings.Queue_Skip}" Command="{Binding SkipQueueItemCommand}"
                                            Padding="8,5" FontSize="11" Style="{StaticResource SecondaryButton}"
                                            ToolTip="{x:Static res:Strings.Queue_SkipTooltip}" />
                                    <Button Content="{x:Static res:Strings.Queue_StopAfterCurrent}" Command="{Binding StopQueueAfterCurrentCommand}"
                                            Margin="6,0,0,0" Padding="8,5" FontSize="11" Style="{StaticResource SecondaryButton}"
                                            ToolTip="{x:Static res:Strings.Queue_StopAfterCurrentTooltip}" />
                                    <Button Content="{x:Static res:Strings.Queue_StopAll}" Command="{Binding StopQueueCommand}"
                                            Margin="6,0,0,0" Padding="8,5" FontSize="11" Style="{StaticResource StopButton}"
                                            ToolTip="{x:Static res:Strings.Queue_StopAllTooltip}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <ListBox Grid.Row="2" Margin="0,16,0,12" ItemsSource="{Binding Estimates}"
                                 SelectedItem="{Binding SelectedEstimate}" Background="Transparent" BorderThickness="0"
                                 Visibility="{Binding EstimateListVisibility}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Margin" Value="0,0,0,7" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="ModeCard" Background="#111318" BorderBrush="#292D35"
                                                        BorderThickness="1" CornerRadius="8" Padding="11">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ModeCard" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                        <Setter TargetName="ModeCard" Property="Background" Value="#1B2518" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{Binding AlgorithmText}" FontWeight="Bold" />
                                            <TextBlock Text="{Binding EstimatedSizeText}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                        </Grid>
                                        <TextBlock Margin="0,5,0,0" Foreground="{StaticResource AccentBrush}">
                                            <Run Text="{x:Static res:Strings.Estimate_SavingsLabel}" /><Run Text="{Binding SavingsText, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding PerformanceText}" Margin="0,4,0,0" FontSize="10"
                                                   TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" />
                                        <Grid Margin="0,3,0,0">
                                            <TextBlock Text="{Binding RatioText}" FontSize="10" Foreground="{StaticResource MutedTextBrush}" />
                                            <TextBlock HorizontalAlignment="Right" FontSize="10" Foreground="{StaticResource MutedTextBrush}">
                                                <Run Text="{x:Static res:Strings.Estimate_ConfidenceLabel}" /><Run Text="{Binding Confidence, Mode=OneWay}" />
                                            </TextBlock>
                                        </Grid>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="2" Margin="0,18,0,12" Padding="18" Background="#111318" CornerRadius="10"
                                VerticalAlignment="Top" Visibility="{Binding AutoInfoVisibility}">
                            <StackPanel>
                                <TextBlock Text="{x:Static res:Strings.Info_AutoTitle}" Foreground="{StaticResource AccentBrush}"
                                           FontSize="11" FontWeight="Bold" />
                                <TextBlock Margin="0,12,0,0" FontSize="13" LineHeight="21" TextWrapping="Wrap"
                                           Text="{x:Static res:Strings.Info_AutoBody}" />
                                <TextBlock Text="{x:Static res:Strings.Info_AutoConfirm}"
                                           Margin="0,14,0,0" FontSize="11" TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Margin="0,18,0,12" Padding="18" Background="#111318" CornerRadius="10"
                                VerticalAlignment="Top" Visibility="{Binding ActiveCompressionInfoVisibility}">
                            <StackPanel>
                                <TextBlock Text="{x:Static res:Strings.Info_ActiveTitle}" Foreground="{StaticResource AccentBrush}"
                                           FontSize="11" FontWeight="Bold" />
                                <TextBlock Text="{Binding ActiveCompressionModeText}" Margin="0,10,0,0"
                                           FontSize="21" FontWeight="Bold" />
                                <TextBlock Text="{Binding ActiveCompressionDetailsText}" Margin="0,6,0,0" FontSize="12"
                                           TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{x:Static res:Strings.Info_ActiveLocked}"
                                           Margin="0,10,0,0" FontSize="11" TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Margin="0,18,0,12" Padding="18" Background="#111318" CornerRadius="10"
                                VerticalAlignment="Top" Visibility="{Binding PartialInfoVisibility}">
                            <StackPanel>
                                <TextBlock Text="{x:Static res:Strings.Info_PartialTitle}" Foreground="#FFB84D" FontSize="11" FontWeight="Bold" />
                                <TextBlock Text="{Binding SelectedGame.CompressionInfoText}" Margin="0,12,0,0"
                                           FontSize="13" LineHeight="22" TextWrapping="Wrap" />
                                <TextBlock Text="{x:Static res:Strings.Info_PartialBody}"
                                           Margin="0,16,0,0" FontSize="11" TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Margin="0,18,0,12" Padding="18" Background="#111318" CornerRadius="10"
                                VerticalAlignment="Top" Visibility="{Binding CompressedPanelVisibility}">
                            <StackPanel>
                                <TextBlock Text="{x:Static res:Strings.Info_CompressedTitle}" Foreground="{StaticResource AccentBrush}"
                                           FontSize="11" FontWeight="Bold" />
                                <TextBlock Text="{Binding SelectedGame.CompressionInfoText}" Margin="0,12,0,0"
                                           FontSize="13" LineHeight="22" TextWrapping="Wrap" />
                                <TextBlock Text="{x:Static res:Strings.Info_CompressedBody}"
                                           Margin="0,16,0,0" FontSize="11" TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="3" Visibility="{Binding AutoOptimizationVisibility}">
                            <TextBlock Text="{Binding ActiveOperationLabel}" Visibility="{Binding ActiveOperationLabelVisibility}"
                                       Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"
                                       Foreground="{StaticResource AccentBrush}" />
                            <Grid Height="22">
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding OperationProgress, Mode=OneWay}"
                                             Background="#292D35" Foreground="{StaticResource AccentBrush}" BorderThickness="0" />
                                <TextBlock Text="{Binding OperationProgressText}" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="White" />
                            </Grid>
                            <TextBlock Text="{Binding OperationSummary}" Margin="0,8,0,10" TextWrapping="Wrap"
                                       FontSize="12" Foreground="{StaticResource MutedTextBrush}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Content="{x:Static res:Strings.Action_Optimize}" Command="{Binding OptimizeCommand}"
                                        Style="{StaticResource PrimaryActionButton}" />
                                <Button Grid.Column="2" Content="{x:Static res:Strings.Action_Stop}" Command="{Binding CancelCurrentCommand}"
                                        Style="{StaticResource StopButton}" />
                            </Grid>
                            <Button Content="{x:Static res:Strings.Action_Decompress}" Command="{Binding DecompressCommand}"
                                    Margin="0,8,0,0" Style="{StaticResource SecondaryActionButton}"
                                    Visibility="{Binding PartiallyCompressedVisibility}"
                                    ToolTip="{x:Static res:Strings.Action_DecompressPartialTooltip}" />
                        </StackPanel>

                        <StackPanel Grid.Row="3" Visibility="{Binding ExpertOptimizationVisibility}">
                            <TextBlock Text="{Binding ActiveOperationLabel}" Visibility="{Binding ActiveOperationLabelVisibility}"
                                       Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"
                                       Foreground="{StaticResource AccentBrush}" />
                            <Grid Height="22">
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding OperationProgress, Mode=OneWay}"
                                             Background="#292D35" Foreground="{StaticResource AccentBrush}" BorderThickness="0" />
                                <TextBlock Text="{Binding OperationProgressText}" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="White" />
                            </Grid>
                            <TextBlock Text="{Binding OperationSummary}" Margin="0,8,0,10" TextWrapping="Wrap"
                                       FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Content="{Binding AnalysisButtonText}" Command="{Binding AnalyzeCommand}"
                                        Style="{StaticResource PrimaryActionButton}" />
                                <Button Grid.Column="2" Content="{x:Static res:Strings.Action_Stop}" Command="{Binding CancelCurrentCommand}"
                                        Style="{StaticResource StopButton}" />
                            </Grid>
                            <Button Content="{x:Static res:Strings.Action_CompressSelected}" Command="{Binding CompressCommand}"
                                    Margin="0,8,0,0" Style="{StaticResource PrimaryActionButton}" />
                            <Button Content="{x:Static res:Strings.Action_Decompress}" Command="{Binding DecompressCommand}"
                                    Margin="0,8,0,0" Style="{StaticResource SecondaryActionButton}"
                                    Visibility="{Binding PartiallyCompressedVisibility}"
                                    ToolTip="{x:Static res:Strings.Action_DecompressPartialTooltip}" />
                        </StackPanel>

                        <StackPanel Grid.Row="3" Visibility="{Binding PartialPanelVisibility}">
                            <TextBlock Text="{Binding ActiveOperationLabel}" Visibility="{Binding ActiveOperationLabelVisibility}"
                                       Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"
                                       Foreground="{StaticResource AccentBrush}" />
                            <Grid Height="22">
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding OperationProgress, Mode=OneWay}"
                                             Background="#292D35" Foreground="{StaticResource AccentBrush}" BorderThickness="0" />
                                <TextBlock Text="{Binding OperationProgressText}" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="White" />
                            </Grid>
                            <TextBlock Text="{Binding OperationSummary}" Margin="0,8,0,10" TextWrapping="Wrap"
                                       FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Content="{Binding FinishCompressionButtonText}" Command="{Binding FinishCompressionCommand}"
                                        Style="{StaticResource PrimaryActionButton}"
                                        ToolTip="{x:Static res:Strings.Action_FinishTooltip}" />
                                <Button Grid.Column="2" Content="{x:Static res:Strings.Action_Stop}" Command="{Binding CancelOperationCommand}"
                                        Style="{StaticResource StopButton}" />
                            </Grid>
                            <Button Content="{x:Static res:Strings.Action_Decompress}" Command="{Binding DecompressCommand}"
                                    Margin="0,8,0,0" Style="{StaticResource SecondaryActionButton}" />
                        </StackPanel>

                        <StackPanel Grid.Row="3" Visibility="{Binding CompressedPanelVisibility}">
                            <TextBlock Text="{Binding ActiveOperationLabel}" Visibility="{Binding ActiveOperationLabelVisibility}"
                                       Margin="0,0,0,6" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"
                                       Foreground="{StaticResource AccentBrush}" />
                            <Grid Height="22">
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding OperationProgress, Mode=OneWay}"
                                             Background="#292D35" Foreground="{StaticResource AccentBrush}" BorderThickness="0" />
                                <TextBlock Text="{Binding OperationProgressText}" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="White" />
                            </Grid>
                            <TextBlock Text="{Binding OperationSummary}" Margin="0,8,0,10" TextWrapping="Wrap"
                                       FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Content="{x:Static res:Strings.Action_Decompress}" Command="{Binding DecompressCommand}"
                                        Style="{StaticResource PrimaryActionButton}" />
                                <Button Grid.Column="2" Content="{x:Static res:Strings.Action_Stop}" Command="{Binding CancelOperationCommand}"
                                        Style="{StaticResource StopButton}" />
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="5" Background="#111318" CornerRadius="8" Padding="12,9">
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
            </Border>
        </Grid>
    </Grid>
</Window>
