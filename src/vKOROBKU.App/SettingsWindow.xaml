<Window x:Class="vKOROBKU.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Width="520" Height="470" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="22" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Настройки" FontSize="25" FontWeight="Bold" />
            <TextBlock Margin="0,7,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}"
                       Text="Наблюдение за сжатыми играми выполняется при запуске приложения и по кнопке «Проверить сейчас»." />
        </StackPanel>

        <CheckBox Grid.Row="2" x:Name="WatcherEnabledBox" Content="Проверять обновления сжатых игр при запуске"
                  Foreground="{StaticResource TextBrush}" FontSize="13" />

        <StackPanel Grid.Row="4">
            <TextBlock Text="ПОРОГ ДЕГРАДАЦИИ СЖАТИЯ, %" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" />
            <TextBox x:Name="DecayBox" Margin="0,7,0,0" Height="38" Padding="10,7"
                     Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                     BorderBrush="#353A44" CaretBrush="{StaticResource AccentBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="6">
            <TextBlock Text="МИНИМАЛЬНАЯ ВЫГОДА ДЛЯ ДОЖАТИЯ, МБ" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" />
            <TextBox x:Name="SavingsBox" Margin="0,7,0,0" Height="38" Padding="10,7"
                     Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                     BorderBrush="#353A44" CaretBrush="{StaticResource AccentBrush}" />
        </StackPanel>

        <TextBlock Grid.Row="8" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" FontSize="11"
                   Text="Игра предлагается к дожатию, когда после обновления потеряна заметная доля экономии (порог в процентах) и возврат места не меньше минимальной выгоды. Оба условия должны выполняться одновременно." />

        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="Сохранить" Click="SaveClick" />
            <Button Grid.Column="2" Content="Отмена" Click="CancelClick" Style="{StaticResource SecondaryButton}" />
        </Grid>
    </Grid>
</Window>
