<Window x:Class="vKOROBKU.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" Width="560" Height="760" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Настройки" FontSize="25" FontWeight="Bold" />
            <TextBlock Margin="0,7,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}"
                       Text="Наблюдение за сжатыми играми выполняется при запуске приложения и по кнопке «Проверить сейчас»." />
        </StackPanel>

        <CheckBox Grid.Row="2" x:Name="WatcherEnabledBox" Content="Проверять обновления сжатых игр при запуске"
                  Foreground="{StaticResource TextBrush}" FontSize="13" />

        <StackPanel Grid.Row="4">
            <TextBlock Text="ПОРОГ ДЕГРАДАЦИИ СЖАТИЯ, %" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" />
            <TextBox x:Name="DecayBox" Margin="0,7,0,0" Height="36" Padding="10,7"
                     Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                     BorderBrush="#353A44" CaretBrush="{StaticResource AccentBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="6">
            <TextBlock Text="МИНИМАЛЬНАЯ ВЫГОДА ДЛЯ ДОЖАТИЯ, МБ" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" />
            <TextBox x:Name="SavingsBox" Margin="0,7,0,0" Height="36" Padding="10,7"
                     Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                     BorderBrush="#353A44" CaretBrush="{StaticResource AccentBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="8">
            <TextBlock Text="НЕСЖИМАЕМЫЕ ТИПЫ ФАЙЛОВ" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" />
            <CheckBox x:Name="SkipEnabledBox" Margin="0,9,0,0" Foreground="{StaticResource TextBrush}" FontSize="13"
                      Content="Пропускать заведомо несжимаемые файлы (медиа, архивы)" />
            <TextBlock x:Name="DefaultListText" Margin="0,7,0,0" TextWrapping="Wrap" FontSize="11"
                       Foreground="{StaticResource MutedTextBrush}" />
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="NewExtensionBox" Height="34" Padding="10,6"
                         Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}"
                         BorderBrush="#353A44" CaretBrush="{StaticResource AccentBrush}"
                         ToolTip="Например: .pak или pak" />
                <Button Grid.Column="2" Content="Добавить" Click="AddExtensionClick" Padding="14,7"
                        Style="{StaticResource SecondaryButton}" />
            </Grid>
            <ListBox x:Name="UserExtensionsList" Margin="0,8,0,0" Height="96"
                     Background="{StaticResource SurfaceBrush}" BorderBrush="#353A44" BorderThickness="1" />
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Content="Удалить выбранное" Click="RemoveExtensionClick" Padding="12,7"
                        Style="{StaticResource SecondaryButton}" />
                <Button Grid.Column="3" Content="Сбросить к стандартному списку" Click="ResetExtensionsClick" Padding="12,7"
                        Style="{StaticResource SecondaryButton}"
                        ToolTip="Удаляет все добавленные вручную расширения" />
            </Grid>
        </StackPanel>

        <Grid Grid.Row="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="Сохранить" Click="SaveClick" />
            <Button Grid.Column="2" Content="Отмена" Click="CancelClick" Style="{StaticResource SecondaryButton}" />
        </Grid>
    </Grid>
</Window>
