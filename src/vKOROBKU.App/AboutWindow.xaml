<Window x:Class="vKOROBKU.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О программе" Width="460" Height="430" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="vKOROBKU" FontSize="28" FontWeight="Black" Foreground="{StaticResource AccentBrush}" />
        <TextBlock Grid.Row="1" x:Name="VersionText" Margin="0,4,0,0" FontSize="13"
                   Foreground="{StaticResource MutedTextBrush}" />

        <TextBlock Grid.Row="3" TextWrapping="Wrap" FontSize="13" LineHeight="20"
                   Text="Сжатие установленных игр штатными средствами Windows (XPRESS/LZX) для экономии места на диске. Игры продолжают работать как раньше — меняется только способ хранения файлов на NTFS." />

        <StackPanel Grid.Row="5">
            <TextBlock FontSize="13" Margin="0,0,0,6">
                <Hyperlink NavigateUri="https://github.com/damnpotato430-eng/vkorobku" RequestNavigate="OnNavigate"
                           Foreground="{StaticResource AccentBrush}">Репозиторий на GitHub</Hyperlink>
            </TextBlock>
            <TextBlock FontSize="13" Margin="0,0,0,6">
                <Hyperlink NavigateUri="https://github.com/damnpotato430-eng/vkorobku/releases/latest" RequestNavigate="OnNavigate"
                           Foreground="{StaticResource AccentBrush}">Последние версии и загрузка</Hyperlink>
            </TextBlock>
            <TextBlock FontSize="13">
                <Hyperlink NavigateUri="https://github.com/damnpotato430-eng/vkorobku/blob/main/LICENSE" RequestNavigate="OnNavigate"
                           Foreground="{StaticResource AccentBrush}">Лицензия GPL-3.0</Hyperlink>
            </TextBlock>
        </StackPanel>

        <Grid Grid.Row="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="Проверить обновления" Click="CheckUpdatesClick" Padding="12,8"
                    Style="{StaticResource SecondaryButton}" />
            <Button Grid.Column="2" Content="Папка логов" Click="OpenLogsClick" Padding="12,8"
                    Style="{StaticResource SecondaryButton}" />
            <Button Grid.Column="4" Content="Закрыть" Click="CloseClick" Padding="16,8" />
        </Grid>
    </Grid>
</Window>
