<Window x:Class="vKOROBKU.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:res="clr-namespace:vKOROBKU.App.Resources"
        Title="{x:Static res:Strings.Nav_About}" Width="460" Height="430" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="vKOROBKU" FontSize="28" FontWeight="Black" Foreground="{StaticResource AccentBrush}" />
        <TextBlock Grid.Row="1" x:Name="VersionText" Margin="0,4,0,0" FontSize="13"
                   Foreground="{StaticResource MutedTextBrush}" />

        <TextBlock Grid.Row="3" TextWrapping="Wrap" FontSize="13" LineHeight="20"
                   Text="{x:Static res:Strings.About_Description}" />

        <StackPanel Grid.Row="5">
            <TextBlock FontSize="13" Margin="0,0,0,6">
                <Hyperlink NavigateUri="https://github.com/damnpotato430-eng/vkorobku" RequestNavigate="OnNavigate"
                           Foreground="{StaticResource AccentBrush}"><Run Text="{x:Static res:Strings.About_RepoLink}" /></Hyperlink>
            </TextBlock>
            <TextBlock FontSize="13" Margin="0,0,0,6">
                <Hyperlink NavigateUri="https://github.com/damnpotato430-eng/vkorobku/releases/latest" RequestNavigate="OnNavigate"
                           Foreground="{StaticResource AccentBrush}"><Run Text="{x:Static res:Strings.About_ReleasesLink}" /></Hyperlink>
            </TextBlock>
            <TextBlock FontSize="13">
                <Hyperlink NavigateUri="https://github.com/damnpotato430-eng/vkorobku/blob/main/LICENSE" RequestNavigate="OnNavigate"
                           Foreground="{StaticResource AccentBrush}"><Run Text="{x:Static res:Strings.About_LicenseLink}" /></Hyperlink>
            </TextBlock>
        </StackPanel>

        <Grid Grid.Row="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="{x:Static res:Strings.About_CheckUpdates}" Click="CheckUpdatesClick" Padding="12,8"
                    Style="{StaticResource SecondaryButton}" />
            <Button Grid.Column="2" Content="{x:Static res:Strings.About_OpenLogs}" Click="OpenLogsClick" Padding="12,8"
                    Style="{StaticResource SecondaryButton}" />
            <Button Grid.Column="4" Content="{x:Static res:Strings.About_Close}" Click="CloseClick" Padding="16,8" />
        </Grid>
    </Grid>
</Window>
